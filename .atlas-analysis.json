  "keyFeatures": [
    "Daily HoYoLAB check-ins for all HoYoverse games",
    "Automatic code redemption for new game codes",
    "View game profiles, real-time notes, and income tracking",
    "Scheduled automation with Discord DM notifications",
    "Multi-game support (Genshin Impact, Honkai Star Rail, ZZZ, Honkai Impact 3rd)",
    "Privacy controls and data management",
    "User settings with caching and rate limiting"
  ],
  "publicApiSurface": [
    "/register - Register your Discord account with HoYoVista",
    "/hoyolink - Link your HoYoLAB account to Discord",
    "/check-in - Perform daily check-in for linked games",
    "/profile - View your game profile information",
    "/notes - Check real-time notes (resin, stamina, etc.)",
    "/income - View monthly income statistics",
    "/redeem - Redeem codes for your games",
    "/settings - Configure bot settings and automation",
    "/data - Manage your stored data",
    "/feedback - Send feedback to developers",
    "/about - View bot information and statistics"
